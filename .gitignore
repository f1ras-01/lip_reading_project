# =============================================================================
#  .gitignore  –  Lip Reader / MIRACL-VC1 project
# =============================================================================
*.gitignore


# ── Large data files (never commit these) ────────────────────────────────────
landmarks.pkl
*.pkl
*.npy
*.npz

# ── Trained models ────────────────────────────────────────────────────────────
*.h5
*.keras
*.pb
*.tflite
saved_model/

# ── Dataset (too large for git — keep on local disk / external drive) ─────────
miraclvc1/
dataset/

# ── TensorBoard logs ──────────────────────────────────────────────────────────
logs/
runs/

# ── Training artefacts ────────────────────────────────────────────────────────
training_history.png
*.png
*.jpg
*.jpeg
!docs/**/*.png         # allow images inside a docs/ folder if you add one

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env
# Conda envs created outside the project are fine (managed by conda itself)
# but if you ever run `conda create --prefix ./env` inside the project:
env/
.conda/

# ── Jupyter / IPython ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE & editor ──────────────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# ── OS artefacts ──────────────────────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# ── Secrets / credentials (safety net) ───────────────────────────────────────
*.pem
*.key
.env
secrets.py
credentials.json

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
tmp/
temp/
scratch/
