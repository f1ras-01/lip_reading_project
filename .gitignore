# =============================================================================
#  .gitignore  –  Lip Reader / MIRACL-VC1 project
#
#  Folder structure tracked by git (contents ignored, folders kept via .gitkeep):
#    data/          <- extracted landmarks  (too large for git)
#    checkpoints/   <- trained model weights (too large / regenerable)
#    plots/         <- training curves (regenerable)
#    logs/          <- TensorBoard events (regenerable)
# =============================================================================

# ── Managed project output folders ───────────────────────────────────────────
#  Ignore everything inside each folder but keep the folder itself via .gitkeep
data/*
!data/.gitkeep

checkpoints/*
!checkpoints/.gitkeep

plots/*
!plots/.gitkeep

logs/*
!logs/.gitkeep

# ── MediaPipe model file (auto-downloaded at runtime, ~29 MB) ─────────────────
face_landmarker.task

# ── Dataset (too large for git — keep on local disk / external drive) ─────────
miraclvc1/

# ── Catch-all for any stray large binary artefacts at the project root ────────
*.pkl
*.npy
*.npz
*.h5
*.keras
*.pb
*.tflite
saved_model/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env

# ── Jupyter / IPython ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE & editor ──────────────────────────────────────────────────────────────
.vscode/
*.code-workspace
.idea/
*.iml
*.swp
*.swo
*~

# ── OS artefacts ──────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
._*

# ── Secrets ───────────────────────────────────────────────────────────────────
*.pem
*.key
secrets.py

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
tmp/
temp/
scratch/
